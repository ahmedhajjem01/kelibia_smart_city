{
  "version": 2,
  "builds": [
    {
      "src": "core/wsgi.py",
      "use": "@vercel/python",
      "config": { "runtime": "python3.12" }
    },
    {
      "src": "frontend-react/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "core/wsgi.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "core/wsgi.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "core/wsgi.py"
    },
    {
      "src": "/media/(.*)",
      "dest": "core/wsgi.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "frontend-react/assets/$1"
    },
    {
      "src": "/favicon.svg",
      "dest": "frontend-react/favicon.svg"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|admin/|static/|media/|assets/|favicon\\.svg).*)",
      "destination": "/frontend-react/index.html"
    }
  ]
}